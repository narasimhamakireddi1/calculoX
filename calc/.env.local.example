# Database (PostgreSQL or PlanetScale)
DATABASE_URL=postgresql://user:password@localhost:5432/calculators

# Redis Cache (Upstash)
REDIS_URL=redis://default:password@localhost:6379

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NextAuth Secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-key-here-32-characters-minimum

# Google Services (optional, for Phase 2)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxx
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Feature Flags
NEXT_PUBLIC_ENABLE_ADSENSE=false
